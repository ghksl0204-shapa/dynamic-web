package com.kh.el.controller;

import java.io.IOException;

import javax.servlet.ServletException;
import javax.servlet.annotation.WebServlet;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

import com.kh.el.model.dto.Person;

@WebServlet("/el.do")
public class ElServlet extends HttpServlet {
	private static final long serialVersionUID = 1L;
       
    public ElServlet() {
        super();
    }

	protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		// 만약 서블릿에서 응답할 데이터가 존재 한다면!!!
		// JSP로 포워딩을 할 때 request.setAttribute("name값", "value값") -> forward ~~
		// request -> Servlet 내장객체 / Scope 객체
		
		// application / session / request / page
		
		/*
		 * 1. application scope : ServletContext
		 * 한 애플리케이션 당, 딱 한개 존재하는 객체
		 * 이 영역에 데이터를 담으면 애플리케이션 전역에서 사용 가능
		 * 
		 * 
		 * 2. session scope : HttpSession
		 * 하나의 브라우저 당, 한 개 존재하는 객체
		 * 이 영역에 데이터를 담으면 JSP / Servlet 단에서 사용 가능
		 * 값이 한 번 담기면 서버를 멈추건, 세션을 비우거나, 브라우저가 닫히기 전까지는 계속 사용 가능
		 * 
		 * 3. request scope : HttpServletRequest
		 * 요청 및 응답 시 매법 생성되는 객체
		 * 이 영역에 데이터를 담으면 해당 request 를 포워딩 받는 응답 JSP 에서만 사용가능 (1회성)
		 * 
		 * 4. page scope : PageContext
		 * JSP페이지에서만 사용가능
		 * 
		 * => 위 객체들에 속성을 추가할 때는 .setAttribute("name값", 벨류);
		 * 							  .getAttribute("namer값");
		 * 							  .removeAttribute("name값");
		 */
		// DTO(VO) 한 개, List<DTO>, int, String
		
		request.setAttribute("classRoom", "501강의장");
		request.setAttribute("student", new Person("홍길동", 15, "한양"));
		
		// 응답 뷰 배정 -> 포워딩
		request.getRequestDispatcher("/WEB-INF/views/01_el.jsp").forward(request, response);
		
	
	}

	protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
		doGet(request, response);
	}
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
}
