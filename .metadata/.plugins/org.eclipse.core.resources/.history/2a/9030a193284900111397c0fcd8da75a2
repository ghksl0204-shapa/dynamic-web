<!-- 
	URI > URL
	
	URI(Uniform Resource Identifier) : 자원을 식별하는 문자열 / 자원의 위치, 네이밍과 상관없이 고유하게 카리킬 수 있는 모든 식별자
	
	URL(Uniform Resource Locator) : Location(위치) 어디로 가면 그걸 찾을 수 있는가에 대한 답
 -->    
<!DOCTYPE html>
<html>
