    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>포함</title>
</head>
<body>

	<h1>include</h1>
	
	<p>
		다른 페이지를 포함할 때
	</p>
	<%-- 정적컴파일 방식 ( 컴파일 시점에 jsp를 포함 시킴 ) 	
	<%@ include file="footer.jsp" %>
	<%@ include file="footer.jsp" %>
	--%>
	
	<h4> JSP 표준 액션 태그를 이용한 방식 (동적 include) </h4>
	
	<jsp:include page="footer.jsp"></jsp:include> <br>

	<!-- 
		XML 기반 기술이기 때문에 반드시 시작 태그와 종료 태그가 쌍으로 존재함!!
		닫는 태그를 작성하지 않으면 500에러 발생
	 -->
	 <jsp:include page="footer.jsp" />











